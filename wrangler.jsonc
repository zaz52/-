{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "weiyiai-portfolio",
  "compatibility_date": "2026-07-06",
  "assets": {
    "directory": "./dist",
    "not_found_handling": "single-page-application"
  },
  "routes": [
    {
      "pattern": "weiyiai.top/*",
      "zone_name": "weiyiai.top"
    },
    {
      "pattern": "www.weiyiai.top/*",
      "zone_name": "weiyiai.top"
    }
  ]
}
